---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = t(locale);

// Array of images for the carousel
const images = Array.from({ length: 14 }, (_, i) => `/demo/${i}.png`);
---

<section class="relative pb-10 md:pb-16 pt-4 md:pt-8" id="projects">
  <div class="section-container">
    <h2 class="text-h2 text-foreground mb-8 md:mb-16 flex flex-col items-start gap-3">
      <span class="flex items-center gap-3">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_12px_rgba(249,115,22,0.5)]"></span>
        {tr.projects.title}
      </span>
      <span class="block h-0.5 w-16 rounded-full bg-gradient-to-r from-primary to-primary/0"></span>
    </h2>

    <!-- Mobile Alert Notification -->
    <div class="block md:hidden mb-8 p-4 rounded-xl border border-primary/30 bg-[rgba(249,115,22,0.08)] backdrop-blur-md shadow-[0_4px_20px_rgba(249,115,22,0.1)] relative" id="projects-mobile-alert">
      <div class="flex gap-3 items-start pr-6">
        <span class="text-xl shrink-0 leading-none">📱</span>
        <p class="text-sm text-foreground/90 leading-relaxed font-medium">
          {tr.projects.mobileAlert}
        </p>
      </div>
      <button class="absolute top-4 right-4 text-primary/70 hover:text-primary transition-colors" onclick="document.getElementById('projects-mobile-alert').style.display='none'">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>

    <div class="grid grid-cols-1 gap-6">
      <!-- Project Card -->
      <div class="liquid-glass-card p-6 md:p-8 cursor-pointer group transition-all duration-300" id="proj1-card">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <span class="text-2xl shrink-0 mt-0.5 text-primary" aria-hidden="true">🏢</span>
            <div>
              <h3 class="text-lg font-display font-semibold text-foreground group-hover:text-primary transition-colors">{tr.projects.proj1.title}</h3>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <a href="https://github.com/Johan0565/street-retail-aggregator" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-primary transition-colors z-10 p-2 rounded-lg hover:bg-white/5" onclick="event.stopPropagation()">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
            </a>
            <svg class="w-5 h-5 text-muted transition-transform duration-300" id="proj1-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </div>
        </div>

        <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-in-out" id="proj1-content-wrapper">
          <div class="overflow-hidden">
            <div class="pt-6 mt-4 border-t border-white/10">
              
              <!-- Stack tags -->
              <div class="flex flex-wrap gap-2 mb-6">
                {tr.projects.proj1.stack.map((tech) => (
                  <span class="px-2.5 py-1.5 rounded-lg bg-primary/10 border border-primary/20 text-xs text-primary font-medium tracking-wide">
                    {tech}
                  </span>
                ))}
              </div>

              <p class="text-base text-subtle leading-relaxed mb-4">{tr.projects.proj1.desc}</p>
              <p class="text-sm text-muted leading-relaxed italic border-l-2 border-primary/50 pl-4 mb-6">{tr.projects.proj1.comment}</p>
              
              <!-- Carousel -->
              <div class="relative w-full aspect-[4/3] sm:aspect-video rounded-xl overflow-hidden bg-transparent" style="perspective: 2000px;" id="proj1-carousel-viewport" onclick="event.stopPropagation()">
                <div class="w-full h-full relative transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)]" style="transform-style: preserve-3d;" id="proj1-carousel-track">
                  {images.map((img, i) => (
                    <div class="absolute inset-0 flex items-center justify-center p-4 carousel-slide" style="backface-visibility: hidden;">
                      <img src={img} alt={`Demo ${i + 1}`} class="max-w-full max-h-full object-contain rounded-lg" loading="lazy" />
                    </div>
                  ))}
                </div>
                
                <!-- Controls -->
                <button class="absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-full bg-black/60 text-white hover:bg-primary transition-colors z-20 focus:outline-none backdrop-blur-md border border-white/10" id="proj1-prev" aria-label="Previous image">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>
                <button class="absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-full bg-black/60 text-white hover:bg-primary transition-colors z-20 focus:outline-none backdrop-blur-md border border-white/10" id="proj1-next" aria-label="Next image">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>
                
                <!-- Indicators -->
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-20 bg-black/50 px-4 py-2 rounded-full backdrop-blur-md max-w-[90%] overflow-x-auto no-scrollbar border border-white/10">
                  {images.map((_, i) => (
                    <button class={`w-2 h-2 shrink-0 rounded-full transition-all duration-300 carousel-dot ${i === 0 ? 'bg-primary scale-125' : 'bg-white/40 hover:bg-white/80'}`} data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Setup event listeners after DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    // Project accordion logic
    const card = document.getElementById('proj1-card');
    const wrapper = document.getElementById('proj1-content-wrapper');
    const chevron = document.getElementById('proj1-chevron');
    let isOpen = false;
  
    if (card && wrapper && chevron) {
      card.addEventListener('click', (e) => {
        // Ignore clicks on links or buttons inside the card
        if (e.target instanceof HTMLElement && (e.target.closest('a') || e.target.closest('button') || e.target.closest('.carousel-dot') || e.target.closest('.carousel-track'))) {
          return;
        }
  
        isOpen = !isOpen;
        if (isOpen) {
          wrapper.style.gridTemplateRows = '1fr';
          chevron.style.transform = 'rotate(180deg)';
        } else {
          wrapper.style.gridTemplateRows = '0fr';
          chevron.style.transform = 'rotate(0deg)';
        }
      });
    }
  
    // Carousel logic (Coverflow Style)
    const track = document.getElementById('proj1-carousel-track');
    const prevBtn = document.getElementById('proj1-prev');
    const nextBtn = document.getElementById('proj1-next');
    const dots = document.querySelectorAll('.carousel-dot');
    const slides = document.querySelectorAll('.carousel-slide');
    
    let currentSlide = 0; // Continuous counter
    const totalSlides = 14;
    
    // We don't need layoutCarousel anymore as the coverflow is calculated dynamically on update
  
    function updateCarousel() {
      if (!track) return;
      
      const activeIndex = ((currentSlide % totalSlides) + totalSlides) % totalSlides;
      
      slides.forEach((slide, i) => {
        const el = slide as HTMLElement;
        let diff = i - activeIndex;
        
        // Wrap around logic for shortest path so carousel loops seamlessly
        if (diff > totalSlides / 2) diff -= totalSlides;
        if (diff < -totalSlides / 2) diff += totalSlides;
        
        const absDiff = Math.abs(diff);
        const direction = diff > 0 ? 1 : -1;
        
        // Base transition for smooth movement
        el.style.transition = 'transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.6s, z-index 0.6s';
        
        if (absDiff === 0) {
          // Center slide
          el.style.transform = 'translateX(0%) translateZ(100px) rotateY(0deg) scale(1)';
          el.style.opacity = '1';
          el.style.zIndex = '20';
          el.style.pointerEvents = 'auto';
        } else if (absDiff <= 3) {
          // Visible side slides
          const direction = diff > 0 ? 1 : -1;
          const xOffset = direction * (30 + absDiff * 12); // Closer: 42%, 54%, 66%
          const zOffset = absDiff * -120; // Slightly less push back
          const yRotation = direction * -50;
          const scale = 1 - (absDiff * 0.1);
          
          el.style.transform = `translateX(${xOffset}%) translateZ(${zOffset}px) rotateY(${yRotation}deg) scale(${scale})`;
          el.style.opacity = (1 - absDiff * 0.25).toString();
          el.style.zIndex = (20 - absDiff).toString();
          el.style.pointerEvents = 'none';
        } else {
          // Hidden slides
          el.style.transform = `translateX(${direction * 100}%) translateZ(-400px) rotateY(0deg) scale(0.5)`;
          el.style.opacity = '0';
          el.style.zIndex = '0';
          el.style.pointerEvents = 'none';
        }
      });
      
      // Update dots
      dots.forEach((dot, index) => {
        if (index === activeIndex) {
          dot.classList.remove('bg-white/40', 'hover:bg-white/80');
          dot.classList.add('bg-primary', 'scale-125');
        } else {
          dot.classList.remove('bg-primary', 'scale-125');
          dot.classList.add('bg-white/40', 'hover:bg-white/80');
        }
      });
    }
    
    // Initial update
    updateCarousel();
  
    if (prevBtn) {
      prevBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        currentSlide--;
        updateCarousel();
      });
    }
  
    if (nextBtn) {
      nextBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        currentSlide++;
        updateCarousel();
      });
    }
  
    dots.forEach(dot => {
      dot.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        const index = parseInt((e.target as HTMLElement).dataset.index || '0');
        
        // Calculate shortest path rotation
        const activeIndex = ((currentSlide % totalSlides) + totalSlides) % totalSlides;
        let diff = index - activeIndex;
        
        // Optimize diff to take the shortest path around the drum
        if (diff > totalSlides / 2) diff -= totalSlides;
        if (diff < -totalSlides / 2) diff += totalSlides;
        
        currentSlide += diff;
        updateCarousel();
      });
    });
    
    // Listen to opening of the accordion to layout properly
    if (card) {
      card.addEventListener('click', () => {
        setTimeout(updateCarousel, 50); // slight delay to allow display
      });
    }
  });
</script>

<style>
  /* Hide scrollbar for the indicators container on smaller screens if there are many dots */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
