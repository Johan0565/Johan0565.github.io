---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = t(locale);
const homeUrl = locale === 'ru' ? '/' : '/en/';
const activityUrl = locale === 'ru' ? '/activity' : '/en/activity';

const currentPath = Astro.url.pathname;
// Using a simple check: if it contains 'activity', it's the activity page
const isActivity = currentPath.includes('/activity');
const isProjects = currentPath.includes('/projects');
const isHome = !isActivity && !isProjects;
---

<header class="fixed z-40 left-1/2 w-auto max-w-[calc(100vw-32px)] header-position" id="site-header">
  <nav class="flex items-center gap-1 sm:gap-2 px-2 sm:px-4 py-2 sm:py-2.5 rounded-2xl border border-edge bg-overlay backdrop-blur-2xl shadow-[var(--shadow-neumorphic)]" style="-webkit-backdrop-filter: blur(40px) saturate(180%);">
    <!-- Nav links -->
    <div class="flex items-center gap-0.5 sm:gap-1">
      <a
        href={homeUrl}
        class={`px-2.5 sm:px-3 py-1.5 rounded-xl text-xs sm:text-sm font-medium text-foreground transition-all duration-200 ${isHome ? 'bg-overlay-hover' : 'hover:bg-overlay-hover'}`}
        aria-current={isHome ? "page" : undefined}
      >
        {tr.nav.about}
      </a>
      <a
        href={activityUrl}
        class={`px-2.5 sm:px-3 py-1.5 rounded-xl text-xs sm:text-sm font-medium text-foreground transition-all duration-200 ${isActivity ? 'bg-overlay-hover' : 'hover:bg-overlay-hover'}`}
        aria-current={isActivity ? "page" : undefined}
      >
        {tr.nav.activity}
      </a>
      <a
        href={locale === 'ru' ? '/projects' : '/en/projects'}
        class={`px-2.5 sm:px-3 py-1.5 rounded-xl text-xs sm:text-sm font-medium text-foreground transition-all duration-200 ${isProjects ? 'bg-overlay-hover' : 'hover:bg-overlay-hover'}`}
        aria-current={isProjects ? "page" : undefined}
      >
        {tr.nav.projects}
      </a>
    </div>

    <!-- Divider -->
    <div class="w-px h-5 bg-edge mx-1 sm:mx-2 shrink-0"></div>

    <!-- Theme Toggle -->
    <ThemeToggle />

    <!-- Divider -->
    <div class="w-px h-5 bg-edge mx-0.5 shrink-0"></div>

    <!-- Language Switcher -->
    <LanguageSwitcher locale={locale} />
  </nav>
</header>

<style>
  /* Desktop: top center */
  .header-position {
    top: 24px;
    bottom: auto;
    transform: translateX(-50%);
  }

  /* Mobile: bottom center */
  @media (max-width: 767px) {
    .header-position {
      top: auto;
      bottom: 24px;
      bottom: max(24px, env(safe-area-inset-bottom, 24px));
    }
  }
</style>
