---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/utils';
import SocialLinks from './SocialLinks.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = t(locale);
---

<section class="relative min-h-[100dvh] flex items-center overflow-hidden" id="hero">



  <div class="section-container relative z-10 pt-12 pb-32 md:py-0">
    <div class="max-w-3xl">

      <div class="flex flex-col items-start md:flex-row md:items-center gap-6 md:gap-10 mb-6 md:mb-8">
        <!-- Avatar photo -->
        <div class="shrink-0">
          <div class="relative inline-block group">
            <!-- Glow on hover -->
            <div class="absolute -inset-3 rounded-full bg-primary/15 blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700" aria-hidden="true"></div>
            <!-- Photo -->
            <div class="relative w-32 h-32 md:w-50 md:h-50 rounded-full overflow-hidden border-2 border-primary/20 shadow-lg shadow-primary/10 transition-transform duration-500 group-hover:scale-105">
              <img
                src="/images/Logo.jpg"
                alt={tr.hero.fullName}
                class="w-full h-full object-cover"
                width="192"
                height="192"
                loading="eager"
              />
            </div>
          </div>
        </div>

        <div>
          <!-- Greeting badge -->
          <div class="mb-3">
            <span class="badge badge-orange">
              <span class="inline-block w-2 h-2 rounded-full bg-primary animate-pulse"></span>
              {tr.hero.greeting}
            </span>
          </div>
          <!-- Name (display heading) -->
          <h1 class="text-display text-foreground m-0">
            {tr.hero.name.split('\n').map((line: string) => (
              <span class="block">
                <span class="text-primary">{line.charAt(0)}</span>{line.slice(1)}
              </span>
            ))}
          </h1>
        </div>
      </div>

      <!-- Title & Location badges -->
      <div class="flex flex-wrap items-center gap-3 mb-6 md:mb-8">
        <span class="badge">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          {tr.hero.title}
        </span>
        <span class="badge">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {tr.hero.location} • {tr.hero.age}
        </span>
      </div>

      <!-- Description -->
      <p class="text-body-lg text-muted max-w-2xl mb-10 md:mb-12">
        {tr.hero.description}
      </p>

      <!-- Social links -->
      <SocialLinks locale={locale} />
    </div>
  </div>
</section>
