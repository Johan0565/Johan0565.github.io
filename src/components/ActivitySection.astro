---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = t(locale);
const { activity, nav } = tr;
---

<section class="relative pb-10 md:pb-16 pt-4 md:pt-8" id="activity">
  <div class="section-container">
    
    <h2 class="text-h2 text-foreground mb-12 md:mb-16 flex flex-col items-start gap-3">
      <span class="flex items-center gap-3">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_12px_rgba(249,115,22,0.5)]"></span>
        {nav.activity}
      </span>
      <span class="block h-0.5 w-16 rounded-full bg-gradient-to-r from-primary to-primary/0"></span>
    </h2>

    <!-- GitHub Activity -->
    <div class="mb-12 md:mb-16">
      <div class="flex flex-col gap-6">
        
        <!-- Graph Card -->
        <div class="liquid-glass-card p-6 md:p-8 flex flex-col h-full w-full relative">
          <!-- Last Updated Label -->
          <span class="absolute top-3 right-4 text-[11px] text-muted/40 font-mono select-none" id="gh-last-updated"></span>
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-4">
            <div class="flex items-start gap-4">
              <span class="text-2xl shrink-0 mt-0.5" aria-hidden="true">📊</span>
              <div>
                <h3 class="text-badge text-primary mb-3">{activity.githubStats}</h3>
                <p class="text-lg font-display font-semibold text-foreground mb-2">{activity.githubGraphTitle}</p>
                <p class="text-sm text-muted leading-relaxed">{activity.githubGraphDesc}</p>
              </div>
            </div>
            <div class="flex gap-2 gh-years shrink-0">
              <button class="gh-year-btn px-3 py-1.5 rounded-xl text-xs font-medium bg-primary text-white transition-colors shadow-[0_0_15px_rgba(249,115,22,0.3)]" data-year="2026">2026</button>
              <button class="gh-year-btn px-3 py-1.5 rounded-xl text-xs font-medium bg-overlay text-foreground border border-edge hover:border-primary/50 transition-colors" data-year="2025">2025</button>
              <button class="gh-year-btn px-3 py-1.5 rounded-xl text-xs font-medium bg-overlay text-foreground border border-edge hover:border-primary/50 transition-colors" data-year="2024">2024</button>
            </div>
          </div>
          
          <div class="mt-4 flex-1 min-h-[180px] flex items-center justify-center overflow-x-auto relative z-10" id="gh-target">
            <p class="text-muted flex items-center gap-3">
              <span class="w-5 h-5 border-2 border-primary border-t-transparent rounded-full animate-spin"></span>
              {activity.loadingGit}
            </p>
          </div>
        </div>
        <div class="liquid-glass-card p-6 md:p-8 h-full w-full expandable-activity-card" id="github-radar-card">
          <button type="button" class="expandable-activity-trigger w-full flex items-start justify-between gap-4 text-left relative z-10" aria-expanded="false" aria-controls="github-radar-panel">
            <span class="flex items-start gap-4">
              <span class="text-2xl shrink-0 mt-0.5" aria-hidden="true">🕸️</span>
              <span>
                <span class="text-badge text-primary mb-3 block">{activity.githubStats}</span>
                <span class="text-lg font-display font-semibold text-foreground mb-2 block">{activity.radarTitle}</span>
                <span class="text-sm text-muted leading-relaxed block">{activity.radarDesc}</span>
              </span>
            </span>
            <svg class="expandable-activity-chevron w-5 h-5 shrink-0 mt-1 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div class="expandable-activity-panel" id="github-radar-panel">
            <div class="expandable-activity-panel-inner">
              <div class="mt-6 min-h-[280px] flex items-center justify-center relative z-10" id="radar-target">
                <canvas id="radar-canvas" width="400" height="400" class="max-w-full h-auto"></canvas>
              </div>
            </div>
          </div>
        </div>

        <!-- Streak Card -->
        <div class="liquid-glass-card p-6 md:p-8 flex flex-col h-full w-full">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-2xl shrink-0 mt-0.5" aria-hidden="true">🔥</span>
            <div>
              <h3 class="text-badge text-primary mb-3">{activity.githubStats}</h3>
              <p class="text-lg font-display font-semibold text-foreground mb-2">{activity.githubStreakTitle}</p>
              <p class="text-sm text-muted leading-relaxed">{activity.githubStreakDesc}</p>
              <div class="flex flex-wrap gap-2 mt-4">
                <span class="px-2.5 py-1 rounded-lg bg-primary/10 border border-primary/20 text-xs text-foreground/70 font-medium">GitHub</span>
                <span class="px-2.5 py-1 rounded-lg bg-primary/10 border border-primary/20 text-xs text-foreground/70 font-medium">Activity</span>
              </div>
            </div>
          </div>
          
          <div class="mt-4 flex-1 flex items-center justify-center overflow-x-auto overflow-y-hidden relative z-10">
            <!-- Light Mode -->
            <img 
              src="https://streak-stats.demolab.com/?user=Johan0565&theme=transparent&hide_border=true&ring=f97316&fire=f97316&currStreakLabel=f97316&sideNums=0f172a&currStreakNum=0f172a&sideLabels=64748b&dates=64748b"
              alt="GitHub Streaks" 
              class="max-w-full h-auto scale-[1.15] transform origin-center gh-streak-light"
              referrerpolicy="no-referrer"
            >
            <!-- Dark Mode -->
            <img 
              src="https://streak-stats.demolab.com/?user=Johan0565&theme=transparent&hide_border=true&ring=f97316&fire=f97316&currStreakLabel=f97316&sideNums=ffffff&currStreakNum=ffffff&sideLabels=94a3b8&dates=94a3b8"
              alt="GitHub Streaks Dark" 
              class="max-w-full h-auto scale-[1.15] transform origin-center gh-streak-dark"
              referrerpolicy="no-referrer"
            >
          </div>
        </div>

        

        <!-- Stepik Combined Card -->
        <div class="liquid-glass-card p-6 md:p-8 flex flex-col lg:flex-row gap-6 h-full w-full relative">
          <!-- Last Updated Label -->
          <span class="absolute top-3 right-4 text-[11px] text-muted/40 font-mono select-none" id="stepik-last-updated"></span>
          <!-- Left: Heatmap -->
          <div class="flex-1 flex flex-col min-w-0">
            <div class="flex items-start gap-4 mb-4">
              <span class="text-2xl shrink-0 mt-0.5" aria-hidden="true">📈</span>
              <div>
                <h3 class="text-badge text-primary mb-3">Stepik</h3>
                <p class="text-lg font-display font-semibold text-foreground mb-2">{activity.stepikGraphTitle}</p>
                <p class="text-sm text-muted leading-relaxed">{activity.stepikGraphDesc}</p>
              </div>
            </div>
            
            <div class="mt-4 flex-1 min-h-[180px] flex items-center justify-start overflow-x-auto relative z-10" id="stepik-target">
              <p class="text-muted flex items-center gap-3" id="stepik-loading">
                <span class="w-5 h-5 border-2 border-primary border-t-transparent rounded-full animate-spin"></span>
                {activity.loadingStepik}
              </p>
            </div>
          </div>

          <!-- Right: Stats -->
          <div class="lg:w-64 shrink-0 flex flex-col justify-center gap-6 border-t lg:border-t-0 lg:border-l border-edge pt-6 lg:pt-0 lg:pl-8">
            <div class="flex flex-col gap-2 group">
              <div class="text-4xl font-display font-bold text-foreground tabular-nums tracking-tight group-hover:text-primary transition-colors duration-300" id="stepik-knowledge">
                --
              </div>
              <div class="text-sm font-medium text-muted uppercase tracking-wider">{activity.stepikKnowledge}</div>
            </div>
            
            <div class="flex flex-col gap-2 group">
              <div class="text-4xl font-display font-bold text-foreground tabular-nums tracking-tight group-hover:text-primary transition-colors duration-300" id="stepik-streak">
                --
              </div>
              <div class="text-sm font-medium text-muted uppercase tracking-wider">{locale === 'ru' ? 'Текущий Стрик' : 'Current Streak'}</div>
            </div>
          </div>
        </div>

        <!-- Duolingo Activity Card -->
        <div class="liquid-glass-card p-6 md:p-8 h-full w-full relative expandable-activity-card" id="duolingo-activity-card">
          <span class="absolute top-3 right-4 text-[11px] text-muted/40 font-mono select-none" id="duolingo-last-updated"></span>
          <button type="button" class="expandable-activity-trigger w-full flex items-start justify-between gap-4 text-left pr-2 relative z-10" aria-expanded="false" aria-controls="duolingo-activity-panel">
            <span class="flex items-start gap-4">
              <img src="/images/duolingoIcon.png" alt="" class="duolingo-mark shrink-0 mt-0.5" width="40" height="40" loading="lazy" decoding="async" aria-hidden="true">
              <span>
                <span class="text-badge text-primary mb-3 block">Duolingo</span>
                <span class="text-lg font-display font-semibold text-foreground mb-2 block">{activity.duolingoTitle}</span>
                <span class="text-sm text-muted leading-relaxed block">{activity.duolingoDesc}</span>
              </span>
            </span>
            <svg class="expandable-activity-chevron w-5 h-5 shrink-0 mt-1 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>

          <div class="expandable-activity-panel" id="duolingo-activity-panel">
            <div class="expandable-activity-panel-inner">
              <div class="pt-6 flex flex-col gap-5 max-w-sm relative z-10">
                <p class="hidden text-sm text-red-400/90" id="duolingo-status"></p>
                <div class="flex flex-col gap-1.5 group">
                  <div class="flex items-center gap-3 text-3xl md:text-4xl font-display font-bold text-foreground tabular-nums tracking-tight group-hover:text-[#58cc02] transition-colors duration-300">
                    <span class="duolingo-stat-icon" aria-hidden="true">
                      <img src="/images/usaIcon.png" alt="" class="duolingo-stat-icon-image" width="48" height="34" loading="lazy" decoding="async">
                    </span>
                    <span id="duolingo-level">--</span>
                  </div>
                  <div class="text-xs sm:text-sm font-medium text-muted uppercase tracking-wider">{activity.duolingoXpLevel}</div>
                </div>
                <div class="flex flex-col gap-1.5 group">
                  <div class="flex items-center gap-3 text-3xl md:text-4xl font-display font-bold text-foreground tabular-nums tracking-tight group-hover:text-[#58cc02] transition-colors duration-300">
                    <span class="duolingo-stat-icon" aria-hidden="true">⚡</span>
                    <span id="duolingo-xp">--</span>
                  </div>
                  <div class="text-xs sm:text-sm font-medium text-muted uppercase tracking-wider">{activity.duolingoCourseXp}</div>
                </div>
                <div class="flex flex-col gap-1.5 group">
                  <div class="flex items-center gap-3 text-3xl md:text-4xl font-display font-bold text-foreground tabular-nums tracking-tight group-hover:text-[#58cc02] transition-colors duration-300">
                    <span class="duolingo-stat-icon" aria-hidden="true">🔥</span>
                    <span id="duolingo-streak">--</span>
                  </div>
                  <div class="text-xs sm:text-sm font-medium text-muted uppercase tracking-wider">{activity.duolingoStreak}</div>
                </div>
                <a href="https://www.duolingo.com/profile/Muhammad73304" target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-[#58cc02] hover:underline relative z-10">@Muhammad73304 →</a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Certificates -->
    <div class="mb-8">
      <h2 class="text-h2 text-foreground mb-6 md:mb-8 flex flex-col items-start gap-3">
        <span class="flex items-center gap-3">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_12px_rgba(249,115,22,0.5)]"></span>
          {activity.certificates}
        </span>
        <span class="block h-0.5 w-16 rounded-full bg-gradient-to-r from-primary to-primary/0"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        <!-- Stepik MySQL -->
        <a href="https://stepik.org/cert/2820543?lang=en" target="_blank" rel="noopener noreferrer" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.certStepik}</h4>
            <p class="text-sm text-muted mt-auto">{activity.certStepikDesc}</p>
          </div>
        </a>

        <!-- Stepik Jira -->
        <a href="https://stepik.org/cert/3293749?lang=en" target="_blank" rel="noopener noreferrer" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.certJira}</h4>
            <p class="text-sm text-muted mt-auto">{activity.certStepikDesc}</p>
          </div>
        </a>

        <!-- Stepik PM -->
        <a href="https://stepik.org/cert/3291171?lang=en" target="_blank" rel="noopener noreferrer" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.certPm}</h4>
            <p class="text-sm text-muted mt-auto">{activity.certStepikDesc}</p>
          </div>
        </a>

        <!-- Stepik PMBOK-7 -->
        <a href="https://stepik.org/cert/3303124?lang=en" target="_blank" rel="noopener noreferrer" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.certPmbok7}</h4>
            <p class="text-sm text-muted mt-auto">{activity.certStepikDesc}</p>
          </div>
        </a>

        <!-- Other -->
        <div class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full" id="open-other-pdf-modal">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z"></path></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.certOther}</h4>
            <p class="text-sm text-muted flex items-center gap-2 mt-auto">
              {activity.certOtherDesc}
              <span class="flex gap-0.5">
                <span class="w-1 h-1 rounded-full bg-muted/60"></span>
                <span class="w-1 h-1 rounded-full bg-muted/60"></span>
                <span class="w-1 h-1 rounded-full bg-muted/60"></span>
              </span>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Other Section -->
    <div class="mb-8">
      <h2 class="text-h2 text-foreground mb-6 md:mb-8 flex flex-col items-start gap-3">
        <span class="flex items-center gap-3">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_12px_rgba(249,115,22,0.5)]"></span>
          {activity.otherSectionTitle}
        </span>
        <span class="block h-0.5 w-16 rounded-full bg-gradient-to-r from-primary to-primary/0"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        <!-- Resume Button -->
        <a href="/resume/resume.pdf" target="_blank" rel="noopener noreferrer" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.resumeBtn}</h4>
            <p class="text-sm text-muted mt-auto">{activity.resumeDesc}</p>
          </div>
        </a>

        <!-- Quote Video Button -->
        <button type="button" id="open-quote-video-modal" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full text-left" aria-haspopup="dialog" aria-controls="quote-video-modal">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5v14l11-7L8 5z"></path></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.quoteBtn}</h4>
            <p class="text-sm text-muted mt-auto">{activity.quoteDesc}</p>
          </div>
        </button>
      </div>
    </div>
  </div>

  <!-- PDF Modal -->
  <div id="pdf-modal" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="absolute inset-0 bg-background/80 backdrop-blur-sm" id="pdf-modal-backdrop"></div>
    <div class="liquid-glass-card relative w-[90%] max-w-lg p-6 md:p-8 flex flex-col gap-6 transform scale-95 transition-transform duration-300" id="pdf-modal-content">
      <div class="flex items-center justify-between">
        <h3 class="text-xl font-display font-semibold text-foreground">{activity.certOtherModalTitle}</h3>
        <button id="close-pdf-modal" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-white/10 text-muted hover:text-foreground transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <div class="flex flex-col gap-4">
        <!-- Item 1 -->
        <a href="/allPDFs/1_nominatsiya_2_mesto_2_komanda.pdf" target="_blank" rel="noopener noreferrer" class="flex items-start gap-4 p-4 rounded-xl border border-edge bg-overlay hover:border-primary/50 hover:bg-overlay-hover transition-all group">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          </div>
          <div>
            <h4 class="text-sm font-medium mb-1 text-foreground group-hover:text-primary transition-colors">{activity.certOtherDiplom}</h4>
            <span class="text-xs text-muted uppercase tracking-wider font-semibold">PDF</span>
          </div>
        </a>
        
        <!-- Item 2 -->
        <a href="/allPDFs/https___study-techtraining.mipt.ru_api_v1_files_8v5e6gWHZ5bHF7YpE.pdf" target="_blank" rel="noopener noreferrer" class="flex items-start gap-4 p-4 rounded-xl border border-edge bg-overlay hover:border-primary/50 hover:bg-overlay-hover transition-all group">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          </div>
          <div>
            <h4 class="text-sm font-medium mb-1 text-foreground group-hover:text-primary transition-colors">{activity.certOtherCertificate}</h4>
            <span class="text-xs text-muted uppercase tracking-wider font-semibold">PDF</span>
          </div>
        </a>
      </div>
    </div>
  </div>

  <!-- Quote Video Modal -->
  <div id="quote-video-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300" role="dialog" aria-modal="true" aria-labelledby="quote-video-title" aria-hidden="true">
    <div class="absolute inset-0 bg-background/85 backdrop-blur-md" id="quote-video-backdrop"></div>
    <div id="quote-video-content" class="quote-video-frame relative w-full max-w-3xl transform scale-95 transition-transform duration-300">
      <div class="flex items-center justify-between gap-4 px-5 py-4 md:px-6">
        <h3 id="quote-video-title" class="text-xl font-display font-semibold text-foreground">{activity.quoteModalTitle}</h3>
        <button type="button" id="close-quote-video-modal" class="w-9 h-9 shrink-0 flex items-center justify-center rounded-full bg-overlay hover:bg-primary/15 text-muted hover:text-primary transition-colors" aria-label={locale === 'ru' ? 'Закрыть видео' : 'Close video'}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <div class="px-3 pb-3 md:px-5 md:pb-5">
        <div class="overflow-hidden rounded-2xl border border-primary/25 bg-black shadow-[0_20px_70px_rgba(0,0,0,0.45)]">
          <video id="quote-video" class="block w-full max-h-[72vh] bg-black object-contain" src="/video.mp4" controls playsinline preload="metadata">
            {locale === 'ru' ? 'Ваш браузер не поддерживает видео.' : 'Your browser does not support video.'}
          </video>
        </div>
      </div>
    </div>
  </div>

</section>

<script>
  const currentLang = document.documentElement.lang || 'ru';
  
  // ───────── Translation helpers ─────────
  const i18n = {
    lastUpdated: currentLang === 'ru' ? 'Обновлено' : 'Updated',
    loading: currentLang === 'ru' ? 'Синхронизация с серверами GitHub...' : 'Syncing with GitHub servers...',
    loadingStepik: currentLang === 'ru' ? 'Загрузка данных Stepik...' : 'Loading Stepik data...',
    ghError: currentLang === 'ru'
      ? 'Не удалось загрузить график. <br><a href="https://github.com/Johan0565" target="_blank" class="text-primary hover:underline font-semibold mt-2 inline-block">Открыть профиль GitHub →</a>'
      : 'Could not load the graph. <br><a href="https://github.com/Johan0565" target="_blank" class="text-primary hover:underline font-semibold mt-2 inline-block">Open GitHub profile →</a>',
    stepikError: currentLang === 'ru' ? 'Не удалось загрузить данные Stepik.' : 'Failed to load Stepik data.',
    radarDays: currentLang === 'ru' ? ['Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб', 'Вс'] : ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
    commits: currentLang === 'ru' ? 'коммитов' : 'commits',
  };

  // ───────── Data cache (per session) ─────────
  const dataCache: Record<string, any> = {};

  // ───────── Fetch from our own API (Netlify Function) with fallback ─────────
  async function fetchActivityData(year: string) {
    const cacheKey = `activity_${year}`;
    if (dataCache[cacheKey]) return dataCache[cacheKey];

    try {
      const res = await fetch(`/api/activity?year=${year}`, { signal: AbortSignal.timeout(12000) });
      if (res.ok) {
        const data = await res.json();
        dataCache[cacheKey] = data;
        return data;
      }
    } catch (e) {
      console.warn('Netlify function failed, falling back to direct proxies...', e);
    }

    // Fallback: try CORS proxies directly (same as old behavior)
    return fetchActivityFallback(year);
  }

  async function fetchActivityFallback(year: string) {
    const ghUrl = `https://github.com/users/Johan0565/contributions?from=${year}-01-01&to=${year}-12-31`;
    const proxies = [
      `https://api.allorigins.win/raw?url=${encodeURIComponent(ghUrl)}`,
      `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(ghUrl)}`,
      `https://corsproxy.io/?${encodeURIComponent(ghUrl)}`,
      `https://corsproxy.org/?url=${encodeURIComponent(ghUrl)}`
    ];

    let githubHtml = null;
    for (const proxy of proxies) {
      try {
        const r = await fetch(proxy, { signal: AbortSignal.timeout(6000) });
        if (r.ok) { githubHtml = await r.text(); break; }
      } catch { /* try next */ }
    }

    // Stepik
    let stepikUser = null;
    let stepikActivity = null;
    async function fetchStepikProxy(url: string) {
      const px = [
        `https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`,
        `https://corsproxy.io/?${encodeURIComponent(url)}`,
      ];
      for (const p of px) {
        try {
          const r = await fetch(p, { signal: AbortSignal.timeout(6000) });
          if (r.ok) return await r.json();
        } catch { /* try next */ }
      }
      return null;
    }

    stepikUser = await fetchStepikProxy('https://stepik.org/api/users/611926268');
    stepikActivity = await fetchStepikProxy('https://stepik.org/api/user-activities/611926268');

    const result = {
      timestamp: new Date().toISOString(),
      year,
      github: githubHtml,
      stepikUser,
      stepikActivity,
    };
    dataCache[`activity_${year}`] = result;
    return result;
  }

  // ───────── Format timestamp ─────────
  function formatTimestamp(iso: string): string {
    try {
      const d = new Date(iso);
      const day = String(d.getDate()).padStart(2, '0');
      const mon = String(d.getMonth() + 1).padStart(2, '0');
      const yr = d.getFullYear();
      const hr = String(d.getHours()).padStart(2, '0');
      const mn = String(d.getMinutes()).padStart(2, '0');
      return `${i18n.lastUpdated}: ${day}.${mon}.${yr} ${hr}:${mn}`;
    } catch { return ''; }
  }

  // ───────── Render GitHub graph ─────────
  function renderGitHubGraph(html: string | null, container: HTMLElement) {
    if (!html) {
      container.innerHTML = `<p class="text-red-400/90 text-sm text-center">${i18n.ghError}</p>`;
      return null;
    }

    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');
    const calendarGraph = doc.querySelector('.js-calendar-graph');
    if (!calendarGraph) {
      container.innerHTML = `<p class="text-red-400/90 text-sm text-center">${i18n.ghError}</p>`;
      return null;
    }

    const graphContent = calendarGraph.querySelector('table') || calendarGraph.querySelector('svg');
    if (!graphContent) {
      container.innerHTML = `<p class="text-red-400/90 text-sm text-center">${i18n.ghError}</p>`;
      return null;
    }

    const wrapper = document.createElement('div');
    wrapper.className = 'js-calendar-graph';
    wrapper.appendChild(graphContent);

    container.innerHTML = '';
    container.appendChild(wrapper);

    container.querySelectorAll('.ContributionCalendar-day').forEach((day: Element) => {
      const hiddenText = day.querySelector('.sr-only');
      if (hiddenText) day.setAttribute('title', (hiddenText as HTMLElement).innerText);
    });

    const svg = container.querySelector('svg');
    if (svg) {
      (svg as HTMLElement).style.width = '100%';
      (svg as HTMLElement).style.height = 'auto';
      (svg as HTMLElement).style.minWidth = '750px';
    }

    const table = container.querySelector('table');
    if (table) {
      table.style.width = 'max-content';
      table.style.margin = '0 auto';
    }

    container.style.setProperty('--color-calendar-graph-day-bg', 'rgba(128, 128, 128, 0.15)');
    container.style.setProperty('--color-calendar-graph-day-border', 'var(--edge)');
    container.style.setProperty('--color-calendar-graph-day-L1-bg', 'rgba(249,115,22,0.3)');
    container.style.setProperty('--color-calendar-graph-day-L2-bg', 'rgba(249,115,22,0.5)');
    container.style.setProperty('--color-calendar-graph-day-L3-bg', 'rgba(249,115,22,0.7)');
    container.style.setProperty('--color-calendar-graph-day-L4-bg', 'rgba(249,115,22,1)');

    // Return parsed day data for the radar chart
    return extractDayData(html);
  }

  // ───────── Extract per-day contribution data from GitHub HTML ─────────
  function extractDayData(html: string): { date: string, count: number }[] {
    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');
    const days: { date: string, count: number }[] = [];

    doc.querySelectorAll('.ContributionCalendar-day').forEach((el: Element) => {
      const date = el.getAttribute('data-date');
      const level = parseInt(el.getAttribute('data-level') || '0', 10);
      // Try to parse actual count from sr-only text
      const srOnly = el.querySelector('.sr-only');
      let count = level; // fallback to level
      if (srOnly) {
        const text = (srOnly as HTMLElement).innerText || (srOnly as HTMLElement).textContent || '';
        const match = text.match(/(\d+)\s+contribution/i);
        if (match) count = parseInt(match[1], 10);
        else if (text.toLowerCase().includes('no contribution')) count = 0;
      }
      if (date) days.push({ date, count });
    });

    return days;
  }

  // ───────── Radar Chart (pure canvas, no library) ─────────
  function renderRadarChart(dayData: { date: string, count: number }[] | null) {
    const canvas = document.getElementById('radar-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Aggregate last 30 days by day of week
    // dayOfWeek: 0=Mon, 1=Tue ... 6=Sun (ISO convention)
    const commitsByDay = [0, 0, 0, 0, 0, 0, 0];

    if (dayData && dayData.length > 0) {
      dayData.forEach(d => {
        const dt = new Date(d.date + 'T00:00:00');
        // JS getDay(): 0=Sun, 1=Mon ...
        let dow = dt.getDay(); // 0=Sun
        // Convert to ISO: 0=Mon ... 6=Sun
        dow = dow === 0 ? 6 : dow - 1;
        commitsByDay[dow] += d.count;
      });
    }

    const labels = i18n.radarDays;
    const numAxes = 7;
    const dpr = window.devicePixelRatio || 1;

    // Make canvas crisp on high-DPI screens
    const displayWidth = canvas.clientWidth || 400;
    const displayHeight = canvas.clientHeight || 400;
    canvas.width = displayWidth * dpr;
    canvas.height = displayHeight * dpr;
    ctx.scale(dpr, dpr);

    const cx = displayWidth / 2;
    const cy = displayHeight / 2;
    const maxRadius = Math.min(cx, cy) - 40;
    const maxVal = Math.max(...commitsByDay, 1);
    const angleStep = (2 * Math.PI) / numAxes;
    const startAngle = -Math.PI / 2; // Start from top

    // Detect dark mode
    const isDark = document.documentElement.classList.contains('dark');
    const gridColor = isDark ? 'rgba(148, 163, 184, 0.12)' : 'rgba(100, 116, 139, 0.12)';
    const labelColor = isDark ? 'rgba(148, 163, 184, 0.8)' : 'rgba(100, 116, 139, 0.8)';
    const primaryRgb = '249, 115, 22'; // orange-500

    // Clear
    ctx.clearRect(0, 0, displayWidth, displayHeight);

    // Draw grid (3 concentric rings)
    const rings = 3;
    for (let r = 1; r <= rings; r++) {
      const radius = (maxRadius / rings) * r;
      ctx.beginPath();
      for (let i = 0; i <= numAxes; i++) {
        const angle = startAngle + i * angleStep;
        const x = cx + radius * Math.cos(angle);
        const y = cy + radius * Math.sin(angle);
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.closePath();
      ctx.strokeStyle = gridColor;
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Draw axis lines
    for (let i = 0; i < numAxes; i++) {
      const angle = startAngle + i * angleStep;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.lineTo(cx + maxRadius * Math.cos(angle), cy + maxRadius * Math.sin(angle));
      ctx.strokeStyle = gridColor;
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // Draw filled data polygon
    ctx.beginPath();
    for (let i = 0; i <= numAxes; i++) {
      const idx = i % numAxes;
      const val = commitsByDay[idx];
      const ratio = val / maxVal;
      const radius = ratio * maxRadius;
      const angle = startAngle + idx * angleStep;
      const x = cx + radius * Math.cos(angle);
      const y = cy + radius * Math.sin(angle);
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.fillStyle = `rgba(${primaryRgb}, 0.15)`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${primaryRgb}, 0.8)`;
    ctx.lineWidth = 2;
    ctx.stroke();

    // Draw data points
    for (let i = 0; i < numAxes; i++) {
      const val = commitsByDay[i];
      const ratio = val / maxVal;
      const radius = ratio * maxRadius;
      const angle = startAngle + i * angleStep;
      const x = cx + radius * Math.cos(angle);
      const y = cy + radius * Math.sin(angle);

      ctx.beginPath();
      ctx.arc(x, y, 4, 0, 2 * Math.PI);
      ctx.fillStyle = `rgb(${primaryRgb})`;
      ctx.fill();
      ctx.strokeStyle = isDark ? '#0f172a' : '#ffffff';
      ctx.lineWidth = 2;
      ctx.stroke();
    }

    // Draw labels
    ctx.font = '13px system-ui, -apple-system, sans-serif';
    ctx.fillStyle = labelColor;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';

    for (let i = 0; i < numAxes; i++) {
      const angle = startAngle + i * angleStep;
      const labelRadius = maxRadius + 22;
      const x = cx + labelRadius * Math.cos(angle);
      const y = cy + labelRadius * Math.sin(angle);
      const val = commitsByDay[i];

      ctx.fillStyle = labelColor;
      ctx.fillText(labels[i], x, y);

      // Small value under the label
      ctx.font = '10px system-ui, -apple-system, sans-serif';
      ctx.fillStyle = `rgba(${primaryRgb}, 0.7)`;
      ctx.fillText(String(val), x, y + 14);
      ctx.font = '13px system-ui, -apple-system, sans-serif';
    }
  }

  // ───────── Render Stepik ─────────
  function renderStepikData(data: any) {
    // Knowledge
    if (data?.stepikUser?.users?.[0]) {
      const knowledgeEl = document.getElementById('stepik-knowledge');
      if (knowledgeEl) knowledgeEl.textContent = String(data.stepikUser.users[0].knowledge || 0);
    }

    // Activity heatmap + streak
    if (data?.stepikActivity?.['user-activities']?.[0]?.pins) {
      const pins = data.stepikActivity['user-activities'][0].pins;
      renderStepikGraph(pins);

      // Calculate streak
      let curStreak = 0;
      for (let i = 364; i >= 0; i--) {
        if (pins[i] > 0) curStreak++;
        else if (curStreak > 0) break;
        else if (i < 363) break;
      }
      let tempStreak = 0, maxStreak = 0;
      for (let i = 0; i < pins.length; i++) {
        if (pins[i] > 0) { tempStreak++; if (tempStreak > maxStreak) maxStreak = tempStreak; }
        else tempStreak = 0;
      }
      const displayStreak = curStreak > 0 ? curStreak : maxStreak;
      const streakEl = document.getElementById('stepik-streak');
      if (streakEl) streakEl.textContent = String(displayStreak);
    }
  }

  function renderStepikGraph(pins: number[]) {
    const target = document.getElementById('stepik-target');
    if (!target) return;

    target.innerHTML = '';
    const graphContainer = document.createElement('div');
    graphContainer.className = 'stepik-calendar-graph';

    pins.forEach(pin => {
      let level = 0;
      if (pin >= 10) level = 4;
      else if (pin >= 6) level = 3;
      else if (pin >= 3) level = 2;
      else if (pin >= 1) level = 1;

      const day = document.createElement('div');
      day.className = 'stepik-day';
      day.setAttribute('data-level', level.toString());
      day.title = `${pin} steps solved`;
      graphContainer.appendChild(day);
    });

    target.appendChild(graphContainer);
  }

  // ───────── Render Duolingo ─────────
  function renderDuolingoData(data: any) {
    const user = data?.duolingo?.users?.[0];
    const status = document.getElementById('duolingo-status');

    if (!user) {
      if (status) {
        status.textContent = currentLang === 'ru' ? 'Не удалось загрузить данные Duolingo.' : 'Failed to load Duolingo data.';
        status.classList.remove('hidden');
      }
      return;
    }

    status?.classList.add('hidden');
    const englishCourse = Array.isArray(user.courses)
      ? user.courses.find((course: any) => course.id === 'DUOLINGO_EN_RU')
      : null;
    const englishXp = Number(englishCourse?.xp || 0);
    const formatter = new Intl.NumberFormat(currentLang === 'ru' ? 'ru-RU' : 'en-US');

    const levelEl = document.getElementById('duolingo-level');
    const xpEl = document.getElementById('duolingo-xp');
    const streakEl = document.getElementById('duolingo-streak');
    // The public Duolingo endpoint does not expose the course level.
    if (levelEl) levelEl.textContent = '34';
    if (xpEl) xpEl.textContent = formatter.format(englishXp);
    if (streakEl) streakEl.textContent = formatter.format(Number(user.streak || 0));
  }

  // ───────── Main: load and render everything ─────────
  async function loadGitHubData(year: string) {
    const container = document.getElementById('gh-target');
    if (!container) return;

    container.innerHTML = `<p class="text-muted flex items-center justify-center gap-3 w-full"><span class="w-5 h-5 border-2 border-primary border-t-transparent rounded-full animate-spin"></span> ${i18n.loading}</p>`;

    // Update year buttons
    document.querySelectorAll('.gh-year-btn').forEach(b => {
      b.classList.remove('bg-primary', 'text-white', 'shadow-[0_0_15px_rgba(249,115,22,0.3)]');
      b.classList.add('bg-overlay', 'text-foreground');
    });
    const activeBtn = document.querySelector(`.gh-year-btn[data-year="${year}"]`);
    if (activeBtn) {
      activeBtn.classList.remove('bg-overlay', 'text-foreground');
      activeBtn.classList.add('bg-primary', 'text-white', 'shadow-[0_0_15px_rgba(249,115,22,0.3)]');
    }

    try {
      const data = await fetchActivityData(year);

      // Show timestamp
      if (data?.timestamp) {
        const ghUpdated = document.getElementById('gh-last-updated');
        if (ghUpdated) ghUpdated.textContent = formatTimestamp(data.timestamp);

        const stepikUpdated = document.getElementById('stepik-last-updated');
        if (stepikUpdated) stepikUpdated.textContent = formatTimestamp(data.timestamp);

        const duolingoUpdated = document.getElementById('duolingo-last-updated');
        if (duolingoUpdated) duolingoUpdated.textContent = formatTimestamp(data.timestamp);
      }

      // Render GitHub graph
      const dayData = renderGitHubGraph(data?.github, container);

      // Render radar chart for the selected year
      renderRadarChart(dayData);

      // Render Stepik (only on initial load — year 2026)
      const currentYear = new Date().getFullYear().toString();
      if (year === currentYear) {
        renderStepikData(data);
        renderDuolingoData(data);
      }
    } catch (error) {
      console.error('Activity load error:', error);
      container.innerHTML = `<p class="text-red-400/90 text-sm text-center">${i18n.ghError}</p>`;
    }
  }

  // ───────── Init ─────────
  document.addEventListener('DOMContentLoaded', () => {
    // Expandable activity cards: click/tap toggles, desktop hover is handled in CSS.
    document.querySelectorAll('.expandable-activity-trigger').forEach(trigger => {
      trigger.addEventListener('click', () => {
        const card = trigger.closest('.expandable-activity-card');
        if (!card) return;
        const expanded = !card.classList.contains('is-expanded');
        card.classList.toggle('is-expanded', expanded);
        card.classList.toggle('is-collapsed', !expanded);
        trigger.setAttribute('aria-expanded', String(expanded));
      });

      trigger.closest('.expandable-activity-card')?.addEventListener('mouseleave', (event) => {
        const card = event.currentTarget as HTMLElement;
        if (!card.classList.contains('is-expanded')) {
          card.classList.remove('is-collapsed');
        }
      });
    });

    document.querySelectorAll('.gh-year-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const year = (e.currentTarget as HTMLElement).dataset.year;
        if (year) loadGitHubData(year);
      });
    });

    // Initial load
    setTimeout(() => {
      loadGitHubData('2026');
    }, 500);

    // Other PDF Modal Logic
    const otherBtn = document.getElementById('open-other-pdf-modal');
    const modal = document.getElementById('pdf-modal');
    const modalContent = document.getElementById('pdf-modal-content');
    const backdrop = document.getElementById('pdf-modal-backdrop');
    const closeBtn = document.getElementById('close-pdf-modal');

    function openModal() {
      if (!modal) return;
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modalContent?.classList.remove('scale-95');
      modalContent?.classList.add('scale-100');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.add('opacity-0', 'pointer-events-none');
      modalContent?.classList.remove('scale-100');
      modalContent?.classList.add('scale-95');
      document.body.style.overflow = '';
    }

    if (otherBtn && modal) {
      otherBtn.addEventListener('click', openModal);
      closeBtn?.addEventListener('click', closeModal);
      backdrop?.addEventListener('click', closeModal);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('opacity-0')) {
          closeModal();
        }
      });
    }

    // Quote Video Modal Logic
    const quoteBtn = document.getElementById('open-quote-video-modal');
    const quoteModal = document.getElementById('quote-video-modal');
    const quoteContent = document.getElementById('quote-video-content');
    const quoteBackdrop = document.getElementById('quote-video-backdrop');
    const quoteCloseBtn = document.getElementById('close-quote-video-modal');
    const quoteVideo = document.getElementById('quote-video') as HTMLVideoElement | null;

    async function openQuoteModal() {
      if (!quoteModal) return;
      quoteModal.classList.remove('opacity-0', 'pointer-events-none');
      quoteModal.setAttribute('aria-hidden', 'false');
      quoteContent?.classList.replace('scale-95', 'scale-100');
      document.body.style.overflow = 'hidden';
      quoteCloseBtn?.focus();

      if (quoteVideo) {
        try {
          await quoteVideo.play();
        } catch {
          // Some browsers only allow automatic playback without sound.
          quoteVideo.muted = true;
          await quoteVideo.play().catch(() => undefined);
        }
      }
    }

    function closeQuoteModal() {
      if (!quoteModal) return;
      quoteVideo?.pause();
      quoteModal.classList.add('opacity-0', 'pointer-events-none');
      quoteModal.setAttribute('aria-hidden', 'true');
      quoteContent?.classList.replace('scale-100', 'scale-95');
      document.body.style.overflow = '';
      quoteBtn?.focus();
    }

    quoteBtn?.addEventListener('click', openQuoteModal);
    quoteCloseBtn?.addEventListener('click', closeQuoteModal);
    quoteBackdrop?.addEventListener('click', closeQuoteModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && quoteModal && !quoteModal.classList.contains('opacity-0')) {
        closeQuoteModal();
      }
    });

    // Re-render radar on theme change
    const observer = new MutationObserver(() => {
      const cachedData = dataCache[`activity_${new Date().getFullYear()}`];
      if (cachedData?.github) {
        const dayData = extractDayData(cachedData.github);
        renderRadarChart(dayData);
      }
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  });
</script>

<style>
  /* Github Graph Styles Override */
  :global(.js-calendar-graph) {
    width: 100%;
    overflow-x: auto;
  }
  :global(.js-calendar-graph table) {
    border-collapse: separate;
    border-spacing: 3px;
  }
  :global(.js-calendar-graph .ContributionCalendar-label) {
    fill: var(--text-muted);
    color: var(--text-muted);
    font-size: 10px;
  }
  :global(.js-calendar-graph .ContributionCalendar-day) {
    shape-rendering: geometricPrecision;
