---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = t(locale);
const { activity, nav } = tr;
---

<section class="relative pb-10 md:pb-16 pt-4 md:pt-8" id="activity">
  <div class="section-container">
    
    <h2 class="text-h2 text-foreground mb-12 md:mb-16 flex flex-col items-start gap-3">
      <span class="flex items-center gap-3">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_12px_rgba(249,115,22,0.5)]"></span>
        {nav.activity}
      </span>
      <span class="block h-0.5 w-16 rounded-full bg-gradient-to-r from-primary to-primary/0"></span>
    </h2>

    <!-- GitHub Activity -->
    <div class="mb-12 md:mb-16">
      <div class="flex flex-col gap-6">
        
        <!-- Graph Card -->
        <div class="liquid-glass-card p-6 md:p-8 flex flex-col h-full w-full">
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-4">
            <div class="flex items-start gap-4">
              <span class="text-2xl shrink-0 mt-0.5" aria-hidden="true">📊</span>
              <div>
                <h3 class="text-badge text-primary mb-3">{activity.githubStats}</h3>
                <p class="text-lg font-display font-semibold text-foreground mb-2">{activity.githubGraphTitle}</p>
                <p class="text-sm text-muted leading-relaxed">{activity.githubGraphDesc}</p>
              </div>
            </div>
            <div class="flex gap-2 gh-years shrink-0">
              <button class="gh-year-btn px-3 py-1.5 rounded-xl text-xs font-medium bg-primary text-white transition-colors shadow-[0_0_15px_rgba(249,115,22,0.3)]" data-year="2026">2026</button>
              <button class="gh-year-btn px-3 py-1.5 rounded-xl text-xs font-medium bg-overlay text-foreground border border-edge hover:border-primary/50 transition-colors" data-year="2025">2025</button>
              <button class="gh-year-btn px-3 py-1.5 rounded-xl text-xs font-medium bg-overlay text-foreground border border-edge hover:border-primary/50 transition-colors" data-year="2024">2024</button>
            </div>
          </div>
          
          <div class="mt-4 flex-1 min-h-[180px] flex items-center justify-center overflow-x-auto relative z-10" id="gh-target">
            <p class="text-muted flex items-center gap-3">
              <span class="w-5 h-5 border-2 border-primary border-t-transparent rounded-full animate-spin"></span>
              {activity.loadingGit}
            </p>
          </div>
        </div>

        <!-- Streak Card -->
        <div class="liquid-glass-card p-6 md:p-8 flex flex-col h-full w-full">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-2xl shrink-0 mt-0.5" aria-hidden="true">🔥</span>
            <div>
              <h3 class="text-badge text-primary mb-3">{activity.githubStats}</h3>
              <p class="text-lg font-display font-semibold text-foreground mb-2">{activity.githubStreakTitle}</p>
              <p class="text-sm text-muted leading-relaxed">{activity.githubStreakDesc}</p>
              <div class="flex flex-wrap gap-2 mt-4">
                <span class="px-2.5 py-1 rounded-lg bg-primary/10 border border-primary/20 text-xs text-foreground/70 font-medium">GitHub</span>
                <span class="px-2.5 py-1 rounded-lg bg-primary/10 border border-primary/20 text-xs text-foreground/70 font-medium">Activity</span>
              </div>
            </div>
          </div>
          
          <div class="mt-4 flex-1 flex items-center justify-center overflow-x-auto overflow-y-hidden relative z-10">
            <!-- Light Mode -->
            <img 
              src="https://github-readme-streak-stats.herokuapp.com/?user=Johan0565&theme=transparent&hide_border=true&ring=f97316&fire=f97316&currStreakLabel=f97316&sideNums=0f172a&currStreakNum=0f172a&sideLabels=64748b&dates=64748b" 
              alt="GitHub Streaks" 
              class="max-w-full h-auto scale-[1.15] transform origin-center gh-streak-light"
              referrerpolicy="no-referrer"
            >
            <!-- Dark Mode -->
            <img 
              src="https://github-readme-streak-stats.herokuapp.com/?user=Johan0565&theme=transparent&hide_border=true&ring=f97316&fire=f97316&currStreakLabel=f97316&sideNums=ffffff&currStreakNum=ffffff&sideLabels=94a3b8&dates=94a3b8" 
              alt="GitHub Streaks Dark" 
              class="max-w-full h-auto scale-[1.15] transform origin-center gh-streak-dark"
              referrerpolicy="no-referrer"
            >
          </div>
        </div>

        <!-- Stepik Combined Card -->
        <div class="liquid-glass-card p-6 md:p-8 flex flex-col lg:flex-row gap-6 h-full w-full">
          <!-- Left: Heatmap -->
          <div class="flex-1 flex flex-col min-w-0">
            <div class="flex items-start gap-4 mb-4">
              <span class="text-2xl shrink-0 mt-0.5" aria-hidden="true">📈</span>
              <div>
                <h3 class="text-badge text-primary mb-3">Stepik</h3>
                <p class="text-lg font-display font-semibold text-foreground mb-2">{activity.stepikGraphTitle}</p>
                <p class="text-sm text-muted leading-relaxed">{activity.stepikGraphDesc}</p>
              </div>
            </div>
            
            <div class="mt-4 flex-1 min-h-[180px] flex items-center justify-start overflow-x-auto relative z-10" id="stepik-target">
              <p class="text-muted flex items-center gap-3" id="stepik-loading">
                <span class="w-5 h-5 border-2 border-primary border-t-transparent rounded-full animate-spin"></span>
                {activity.loadingStepik}
              </p>
            </div>
          </div>

          <!-- Right: Stats -->
          <div class="lg:w-64 shrink-0 flex flex-col justify-center gap-6 border-t lg:border-t-0 lg:border-l border-edge pt-6 lg:pt-0 lg:pl-8">
            <div class="flex flex-col gap-2 group">
              <div class="text-4xl font-display font-bold text-foreground tabular-nums tracking-tight group-hover:text-primary transition-colors duration-300" id="stepik-knowledge">
                --
              </div>
              <div class="text-sm font-medium text-muted uppercase tracking-wider">{activity.stepikKnowledge}</div>
            </div>
            
            <div class="flex flex-col gap-2 group">
              <div class="text-4xl font-display font-bold text-foreground tabular-nums tracking-tight group-hover:text-primary transition-colors duration-300" id="stepik-streak">
                --
              </div>
              <div class="text-sm font-medium text-muted uppercase tracking-wider">{locale === 'ru' ? 'Текущий Стрик' : 'Current Streak'}</div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Certificates -->
    <div class="mb-8">
      <h2 class="text-h2 text-foreground mb-6 md:mb-8 flex flex-col items-start gap-3">
        <span class="flex items-center gap-3">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_12px_rgba(249,115,22,0.5)]"></span>
          {activity.certificates}
        </span>
        <span class="block h-0.5 w-16 rounded-full bg-gradient-to-r from-primary to-primary/0"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        <!-- Stepik MySQL -->
        <a href="https://stepik.org/cert/2820543?lang=en" target="_blank" rel="noopener noreferrer" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.certStepik}</h4>
            <p class="text-sm text-muted mt-auto">{activity.certStepikDesc}</p>
          </div>
        </a>

        <!-- Stepik Jira -->
        <a href="https://stepik.org/cert/3293749?lang=en" target="_blank" rel="noopener noreferrer" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.certJira}</h4>
            <p class="text-sm text-muted mt-auto">{activity.certStepikDesc}</p>
          </div>
        </a>

        <!-- Stepik PM -->
        <a href="https://stepik.org/cert/3291171?lang=en" target="_blank" rel="noopener noreferrer" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.certPm}</h4>
            <p class="text-sm text-muted mt-auto">{activity.certStepikDesc}</p>
          </div>
        </a>

        <!-- Stepik PMBOK-7 -->
        <a href="https://stepik.org/cert/3303124?lang=en" target="_blank" rel="noopener noreferrer" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.certPmbok7}</h4>
            <p class="text-sm text-muted mt-auto">{activity.certStepikDesc}</p>
          </div>
        </a>

        <!-- Other -->
        <div class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full" id="open-other-pdf-modal">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z"></path></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.certOther}</h4>
            <p class="text-sm text-muted flex items-center gap-2 mt-auto">
              {activity.certOtherDesc}
              <span class="flex gap-0.5">
                <span class="w-1 h-1 rounded-full bg-muted/60"></span>
                <span class="w-1 h-1 rounded-full bg-muted/60"></span>
                <span class="w-1 h-1 rounded-full bg-muted/60"></span>
              </span>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Other Section -->
    <div class="mb-8">
      <h2 class="text-h2 text-foreground mb-6 md:mb-8 flex flex-col items-start gap-3">
        <span class="flex items-center gap-3">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-primary shadow-[0_0_12px_rgba(249,115,22,0.5)]"></span>
          {activity.otherSectionTitle}
        </span>
        <span class="block h-0.5 w-16 rounded-full bg-gradient-to-r from-primary to-primary/0"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        <!-- Resume Button -->
        <a href="/resume/resume.pdf" target="_blank" rel="noopener noreferrer" class="liquid-glass-card p-6 flex flex-col items-start gap-4 hover:border-primary/40 transition-colors group cursor-pointer relative z-10 h-full">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary text-xl group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path></svg>
          </div>
          <div class="flex flex-col flex-1 w-full">
            <h4 class="text-foreground font-semibold mb-2 group-hover:text-primary transition-colors">{activity.resumeBtn}</h4>
            <p class="text-sm text-muted mt-auto">{activity.resumeDesc}</p>
          </div>
        </a>
      </div>
    </div>
  </div>

  <!-- PDF Modal -->
  <div id="pdf-modal" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="absolute inset-0 bg-background/80 backdrop-blur-sm" id="pdf-modal-backdrop"></div>
    <div class="liquid-glass-card relative w-[90%] max-w-lg p-6 md:p-8 flex flex-col gap-6 transform scale-95 transition-transform duration-300" id="pdf-modal-content">
      <div class="flex items-center justify-between">
        <h3 class="text-xl font-display font-semibold text-foreground">{activity.certOtherModalTitle}</h3>
        <button id="close-pdf-modal" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-white/10 text-muted hover:text-foreground transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <div class="flex flex-col gap-4">
        <!-- Item 1 -->
        <a href="/allPDFs/1_nominatsiya_2_mesto_2_komanda.pdf" target="_blank" rel="noopener noreferrer" class="flex items-start gap-4 p-4 rounded-xl border border-edge bg-overlay hover:border-primary/50 hover:bg-overlay-hover transition-all group">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          </div>
          <div>
            <h4 class="text-sm font-medium mb-1 text-foreground group-hover:text-primary transition-colors">{activity.certOtherDiplom}</h4>
            <span class="text-xs text-muted uppercase tracking-wider font-semibold">PDF</span>
          </div>
        </a>
        
        <!-- Item 2 -->
        <a href="/allPDFs/https___study-techtraining.mipt.ru_api_v1_files_8v5e6gWHZ5bHF7YpE.pdf" target="_blank" rel="noopener noreferrer" class="flex items-start gap-4 p-4 rounded-xl border border-edge bg-overlay hover:border-primary/50 hover:bg-overlay-hover transition-all group">
          <div class="w-10 h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          </div>
          <div>
            <h4 class="text-sm font-medium mb-1 text-foreground group-hover:text-primary transition-colors">{activity.certOtherCertificate}</h4>
            <span class="text-xs text-muted uppercase tracking-wider font-semibold">PDF</span>
          </div>
        </a>
      </div>
    </div>
  </div>

</section>

<script>
  let currentLang = document.documentElement.lang || 'ru';
  
  async function loadGitHubData(year) {
    const container = document.getElementById('gh-target');
    if (!container) return;
    
    const langWait = currentLang === 'ru' ? 'Синхронизация с серверами GitHub...' : 'Syncing with GitHub servers...';
    
    container.innerHTML = `<p class="text-muted flex items-center justify-center gap-3 w-full"><span class="w-5 h-5 border-2 border-primary border-t-transparent rounded-full animate-spin"></span> ${langWait}</p>`;
    
    document.querySelectorAll('.gh-year-btn').forEach(b => {
      b.classList.remove('bg-primary', 'text-white', 'shadow-[0_0_15px_rgba(249,115,22,0.3)]');
      b.classList.add('bg-overlay', 'text-foreground');
    });
    
    const activeBtn = document.querySelector(`.gh-year-btn[data-year="${year}"]`);
    if (activeBtn) {
      activeBtn.classList.remove('bg-overlay', 'text-foreground');
      activeBtn.classList.add('bg-primary', 'text-white', 'shadow-[0_0_15px_rgba(249,115,22,0.3)]');
    }
    
    const url = `https://github.com/users/Johan0565/contributions?from=${year}-01-01&to=${year}-12-31`;
    const proxies = [
        `https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`,
        `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(url)}`,
        `https://corsproxy.io/?${encodeURIComponent(url)}`,
        `https://corsproxy.org/?url=${encodeURIComponent(url)}`
    ];
    
    async function fetchGraph(proxyUrl) {
        const controller = new AbortController();
        const timeout = setTimeout(() => controller.abort(), 6000);
        try {
            const response = await fetch(proxyUrl, { signal: controller.signal });
            clearTimeout(timeout);
            if (!response.ok) throw new Error('HTTP ' + response.status);
            const html = await response.text(); 
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const calendarGraph = doc.querySelector('.js-calendar-graph');
            if (!calendarGraph) throw new Error('Graph element not found');
            
            // Extract only the table or SVG to avoid the footer text
            const graphContent = calendarGraph.querySelector('table') || calendarGraph.querySelector('svg');
            if (!graphContent) throw new Error('Graph content not found');
            
            const wrapper = document.createElement('div');
            wrapper.className = 'js-calendar-graph';
            wrapper.appendChild(graphContent);
            return wrapper;
        } catch (e) {
            clearTimeout(timeout);
            throw e;
        }
    }
    
    try {
        let calendarGraph = null;
        for (let i = 0; i < proxies.length; i++) {
            try {
                calendarGraph = await fetchGraph(proxies[i]);
                break;
            } catch (e) {
                console.log(`Proxy ${i + 1} failed: ${e.message}, trying next...`);
            }
        }
        if (!calendarGraph) throw new Error('All proxies failed');
        container.innerHTML = '';
        container.appendChild(calendarGraph);
        
        container.querySelectorAll('.ContributionCalendar-day').forEach(day => {
            const hiddenText = day.querySelector('.sr-only');
            if (hiddenText) {
                day.setAttribute('title', hiddenText.innerText);
            }
        });
        
        const svg = container.querySelector('svg');
        if (svg) {
            svg.style.width = '100%';
            svg.style.height = 'auto';
            svg.style.minWidth = '750px'; 
        }
        
        const table = container.querySelector('table');
        if (table) {
            table.style.width = 'max-content';
            table.style.margin = '0 auto';
        }
            
        // Apply theme colors to github graph variables
        container.style.setProperty('--color-calendar-graph-day-bg', 'rgba(128, 128, 128, 0.15)'); // Gray tint for empty cells
        container.style.setProperty('--color-calendar-graph-day-border', 'var(--edge)');
        container.style.setProperty('--color-calendar-graph-day-L1-bg', 'rgba(249,115,22,0.3)');
        container.style.setProperty('--color-calendar-graph-day-L2-bg', 'rgba(249,115,22,0.5)');
        container.style.setProperty('--color-calendar-graph-day-L3-bg', 'rgba(249,115,22,0.7)');
        container.style.setProperty('--color-calendar-graph-day-L4-bg', 'rgba(249,115,22,1)');
        
    } catch (error) {
        console.error("GitHub parsing error: ", error);
        const errMsg = currentLang === 'ru'
            ? 'Не удалось загрузить график. Прокси-серверы временно недоступны. <br><a href="https://github.com/Johan0565" target="_blank" class="text-primary hover:underline font-semibold mt-2 inline-block">Открыть профиль GitHub →</a>'
            : 'Could not load the graph. Proxy servers are temporarily unavailable. <br><a href="https://github.com/Johan0565" target="_blank" class="text-primary hover:underline font-semibold mt-2 inline-block">Open GitHub profile →</a>';
        container.innerHTML = `<p class="text-red-400/90 text-sm text-center">${errMsg}</p>`;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.gh-year-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
              const year = (e.currentTarget as HTMLElement).dataset.year;
              if (year) loadGitHubData(year);
          });
      });
      
      // Initial load
      setTimeout(() => {
          loadGitHubData('2026');
      }, 500);

      // Other PDF Modal Logic
      const otherBtn = document.getElementById('open-other-pdf-modal');
      const modal = document.getElementById('pdf-modal');
      const modalContent = document.getElementById('pdf-modal-content');
      const backdrop = document.getElementById('pdf-modal-backdrop');
      const closeBtn = document.getElementById('close-pdf-modal');

      function openModal() {
          if (!modal) return;
          modal.classList.remove('opacity-0', 'pointer-events-none');
          modalContent.classList.remove('scale-95');
          modalContent.classList.add('scale-100');
          document.body.style.overflow = 'hidden';
      }

      function closeModal() {
          if (!modal) return;
          modal.classList.add('opacity-0', 'pointer-events-none');
          modalContent.classList.remove('scale-100');
          modalContent.classList.add('scale-95');
          document.body.style.overflow = '';
      }

      if (otherBtn && modal) {
          otherBtn.addEventListener('click', openModal);
          closeBtn.addEventListener('click', closeModal);
          backdrop.addEventListener('click', closeModal);
          
          document.addEventListener('keydown', (e) => {
              if (e.key === 'Escape' && !modal.classList.contains('opacity-0')) {
                  closeModal();
              }
          });
      }

      // Stepik API Logic
      async function fetchWithProxies(targetUrl) {
        const proxies = [
          `https://api.allorigins.win/raw?url=${encodeURIComponent(targetUrl)}`,
          `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(targetUrl)}`,
          `https://corsproxy.io/?${encodeURIComponent(targetUrl)}`,
          `https://corsproxy.org/?url=${encodeURIComponent(targetUrl)}`
        ];
        
        for (let proxy of proxies) {
          try {
            const controller = new AbortController();
            const timeout = setTimeout(() => controller.abort(), 6000);
            const res = await fetch(proxy, { signal: controller.signal });
            clearTimeout(timeout);
            if (res.ok) {
              const data = await res.json();
              return data;
            }
          } catch (e) {
            console.log(`Stepik proxy failed, trying next...`);
          }
        }
        throw new Error('All Stepik proxies failed');
      }

      async function fetchStepikData() {
        try {
          // Fetch user stats
          const userData = await fetchWithProxies('https://stepik.org/api/users/611926268');
          if (userData && userData.users && userData.users.length > 0) {
            document.getElementById('stepik-knowledge').textContent = userData.users[0].knowledge || 0;
          }

          // Delay to prevent free CORS proxies (like corsproxy.io) from rate-limiting the second request
          await new Promise(resolve => setTimeout(resolve, 2000));

          // Fetch user activities (heatmap)
          const activityData = await fetchWithProxies('https://stepik.org/api/user-activities/611926268');
          if (activityData && activityData['user-activities'] && activityData['user-activities'].length > 0) {
            const pins = activityData['user-activities'][0].pins; // 365 elements
            renderStepikGraph(pins);
            
            // Calculate streak
            // pins array: usually pins[364] is today. But if the zeroes are at the end, 
            // Stepik might return pins[0] as today, or the user hasn't been active for months.
            // Let's find the current streak by counting consecutive non-zeroes from the end of the active period.
            // Actually, let's just find the max streak if current streak is 0, or just calculate current streak properly.
            // Let's assume pins[364] is today (standard for 365-day arrays).
            let currentStreak = 0;
            // Let's check if the array is reversed (if recent days are at the beginning).
            // Usually, pins[364] is today.
            let isReversed = false;
            // A simple heuristic: find the longest streak just to be safe and show it.
            let tempStreak = 0;
            let maxStreak = 0;
            for (let i = 0; i < pins.length; i++) {
                if (pins[i] > 0) {
                    tempStreak++;
                    if (tempStreak > maxStreak) maxStreak = tempStreak;
                } else {
                    tempStreak = 0;
                }
            }
            
            // For current streak, let's just count backwards from 364
            let curStreak = 0;
            for (let i = 364; i >= 0; i--) {
                if (pins[i] > 0) curStreak++;
                else if (curStreak > 0) break; // broke the streak
                // if we hit 0 and haven't started a streak, we check if i == 364 or 363 (maybe today is 0 but yesterday was active)
                else if (i < 363) break; 
            }
            // If the user's pins are at the beginning, we fallback to maxStreak or another calculation
            let displayStreak = curStreak > 0 ? curStreak : maxStreak;
            
            document.getElementById('stepik-streak').textContent = displayStreak;
          }
        } catch (err) {
          console.error(err);
          const target = document.getElementById('stepik-target');
          if (target) {
            target.innerHTML = `<p class="text-sm text-red-500">${currentLang === 'ru' ? 'Не удалось загрузить данные Stepik.' : 'Failed to load Stepik data.'}</p>`;
          }
        }
      }

      function renderStepikGraph(pins) {
        const target = document.getElementById('stepik-target');
        if (!target) return;
        
        target.innerHTML = '';
        const graphContainer = document.createElement('div');
        graphContainer.className = 'stepik-calendar-graph';
        
        // Render 365 days
        pins.forEach(pin => {
          let level = 0;
          if (pin >= 10) level = 4;
          else if (pin >= 6) level = 3;
          else if (pin >= 3) level = 2;
          else if (pin >= 1) level = 1;
          
          const day = document.createElement('div');
          day.className = 'stepik-day';
          day.setAttribute('data-level', level.toString());
          day.title = `${pin} steps solved`;
          graphContainer.appendChild(day);
        });
        
        target.appendChild(graphContainer);
      }
      
      fetchStepikData();
  });
</script>

