---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/utils';


interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = t(locale);
---

<footer class="relative mt-32 pb-8 md:pb-12" id="footer">
  <!-- Top border glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 h-0.5 w-72 rounded-full bg-gradient-to-r from-primary/0 via-primary to-primary/0"></div>

  <div class="section-container pt-12 md:pt-16">
    <div class="flex flex-col items-center justify-center">
      <!-- Copyright -->
      <div class="text-sm text-muted text-center flex flex-col gap-2">
        <p>{tr.footer.copyright}</p>
        <p class="text-xs text-subtle">{tr.footer.hostedBy} <a href="https://www.netlify.com/" target="_blank" rel="noopener noreferrer" class="text-primary font-medium hover:underline hover:text-orange-400 transition-colors">Netlify</a></p>
      </div>
    </div>
  </div>

  <!-- Bottom safe area for mobile nav -->
  <div class="h-20 md:h-0"></div>
</footer>
